# ---- Local development ----
# Copy this file to ".env" and fill in the values. Never commit ".env".

# Your key from https://www.thecardapi.com/pricing (free, no card required)
THECARDAPI_KEY=tca_your_key_here

# Users who can log in. Format: "username:password" pairs, comma-separated.
# Usernames are case-insensitive. Use strong passwords for a public deployment.
APP_USERS=alice:changeme1,bob:changeme2

# Secret used to sign login session cookies. Use a long random string.
# Locally you can leave the default; in production this MUST be set (Render
# generates one automatically via render.yaml).
SESSION_SECRET=use-a-long-random-string-here

# Optional: port for local runs (default 3000)
PORT=3000

# Optional: where the SQLite file lives. Defaults to ./collection.db locally.
# On Render this is set to the mounted disk path automatically.
# DB_PATH=/var/data/collection.db
